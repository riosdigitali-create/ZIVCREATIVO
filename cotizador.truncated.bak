      <div class="cot-search-inner">
        <span class="cot-search-icon">/</span>
        <input class="cot-input" id="bizSearch" type="text" placeholder="ej: salón de uñas, restaurante, inmobiliaria…" autocomplete="off" spellcheck="false" autofocus>
